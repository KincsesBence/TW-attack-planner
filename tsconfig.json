{
    "compilerOptions": {
      "rootDir": "./src",
      "outDir": "./dist",
      "noImplicitAny": true,
      "module": "es6",
      "target": "es2021",
      "jsx": "react",
      "allowJs": true,
      "emitDecoratorMetadata": true,
      "experimentalDecorators": true,
      "moduleResolution": "bundler",
      "types": ["jquery", "jqueryui"],
      "strict": false
    },
    "include": ["src", "globals.d.ts"]
  }